#Line Messaging API credentials
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# MySQL Database Configuration
# DB_BACKEND: auto（預設）| json | mysql。auto = 有設 MYSQL_HOST 或
# MYSQL_UNIX_SOCKET 就用 MySQL，否則退回本機 JSON 檔。
DB_BACKEND=auto
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
# 二選一：TCP（本機 docker=db、Cloud SQL Public IP、Auth Proxy=127.0.0.1）
MYSQL_HOST=
MYSQL_PORT=3306
# 或 Cloud Run / App Engine 掛 Cloud SQL 用 unix socket：
# MYSQL_UNIX_SOCKET=/cloudsql/<PROJECT>:<REGION>:<INSTANCE>
MYSQL_UNIX_SOCKET=

#LINE Login credentials
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=

# 真正的 SAM 自動分割參數
SAM_CHECKPOINT=models/mobile_sam.pt
SAM_MODEL_TYPE=vit_t
SAM_POINTS_PER_SIDE=
SAM_MIN_MASK_REGION_AREA=

# GCP
GCP_PROJECT=
CLOUD_SQL_INSTANCE=
DB_NAME=
DB_USER=
DB_PASSWORD=
GCS_BUCKET=